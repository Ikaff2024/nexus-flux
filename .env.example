# Example environment configuration for Nexus-Flux
# Copy this file to `.env` and fill in the required values.

# ================================
#  LLM & API Configuration
# ================================
# Insert your OpenAI or compatible LLM API key
LLM_API_KEY="your_api_key_here"

# Embedding and generation models
LLM_EMBEDDING_MODEL="text-embedding-3-small"
LLM_GENERATION_MODEL="gpt-4-turbo-preview"

# Timeout (in seconds) for API calls
LLM_API_TIMEOUT=30

# Number of automatic retries on rate limits / timeouts
LLM_MAX_RETRIES=3

# ================================
#  Nexus-Flux Engine Settings
# ================================
# Dimensionality of the embedding vectors
EMBEDDING_DIM=1536

# Maximum number of cognitive ticks
MAX_TICKS=20

# Convergence threshold for the global momentum
CONVERGENCE_THRESHOLD=0.005

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# ================================
#  State Backend
# ================================
# "memory" for in-memory backend
# "redis" for Redis-based backend
STATE_BACKEND="memory"

# Redis connection URL (only used if STATE_BACKEND="redis")
REDIS_URL="redis://localhost:6379"

# ================================
#  Security & Execution
# ================================
# Enable or disable PragmaticAgent execution
ENABLE_PRAGMATIC_AGENT="true"
